# APPLICATION
PORT=8080
NODE_ENV=development

# DATABASE
DB_HOST=localhost
DB_PORT=27017
DB_USER=root
DB_PASSWORD=root
DB_NAME=green_life_db

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
