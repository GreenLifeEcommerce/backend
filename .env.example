# JWT
JWT_SECRET=your-secret-key
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

# SWAGGER
SWAGGER_SITE_TITLE=Green Life API
SWAGGER_DOC_TITLE=Green Life
